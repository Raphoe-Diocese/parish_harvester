# Parish Bulletin Harvester - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# AI Services (optional — OCR summaries and event extraction only)
# =============================================================================

# Mistral — bulletin OCR and reader summaries
# Get your free key at: https://console.mistral.ai/
MISTRAL_API_KEY=

# Google Gemini / Groq — event extraction fallback chain
GEMINI_API_KEY=

# OpenAI — optional OCR fallback
OPENAI_API_KEY=

# =============================================================================
# Email Notifications (optional - for harvest digest emails)
# =============================================================================

# Option 1: SMTP (Generic email server)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=
SMTP_FROM=your-email@example.com
SMTP_TO=recipient@example.com

# Option 2: SendGrid (Transactional email service)
SENDGRID_API_KEY=
SENDGRID_FROM=your-email@example.com
SENDGRID_TO=recipient@example.com

# Option 3: Mailgun (Email API service)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=mailgun@mg.yourdomain.com
MAILGUN_TO=recipient@example.com

# =============================================================================
# Harvest Configuration (optional overrides)
# =============================================================================

# Disable AI summaries for bulletins (saves API calls)
# PARISH_AI_SUMMARIES_DISABLE=1

# Disable priority queue (harvest in alphabetical order instead)
# PARISH_HARVEST_NO_PRIORITY=1

# =============================================================================
# GitHub (required for extension recipe saving)
# =============================================================================

# GitHub Personal Access Token with repo write permissions
# Create at: https://github.com/settings/tokens
# Required for Chrome extension to save recipes back to repo
GH_PAT=

# Your GitHub repository (format: username/repo-name)
GH_REPO=Frankytyrone/parish_harvester

# =============================================================================
# Chrome Extension Settings
# =============================================================================
# Note: Extension settings are configured in the extension popup UI

# =============================================================================
# Development / Testing
# =============================================================================

# Enable debug logging
# DEBUG=1

# Pytest options (optional)
# PYTEST_ADDOPTS=-v --tb=short
