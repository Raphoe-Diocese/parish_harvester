        "a[href$='.pdf']",
        "a[href*='.pdf']",
        "div > div:nth-of-type(2) > div > ul > li:nth-of-type(4) > a"
      ]
    },
    {
      "action": "click",
      "selector": "a:has-text('Accept')",
      "fallback_selectors": [
        "a[href$='.pdf']",
        "a[href*='.pdf']",
        "html > body > div:nth-of-type(5) > div > a:nth-of-type(2)"
      ]
    },
    {
      "action": "download",
      "url_pattern": "*.pdf",
      "captured_url": "no_bulletin"
    }
  ],
  "diocese": "down_and_connor"
