{
  "parish_key": "bangorparish",
  "display_name": "Bangor",
  "recorded_date": "2026-04-28",
  "start_url": "https://www.bangorparish.com/parish-bulletin/",
  "steps": [
    {
      "action": "goto",
      "url": "https://www.bangorparish.com/parish-bulletin/"
    },
    {
      "action": "click",
      "selector": "a:has-text('Newsletter')",
      "fallback_selectors": [
        "a[href*='newsletter'][href$='.pdf']",
        "a[href$='.pdf']",
        "a[href*='.pdf']",
        "div > main > article > div > p:nth-of-type(5) > a:nth-of-type(1)"
      ]
    },
    {
      "action": "download",
      "url_pattern": "*.pdf"
    }
  ],
  "diocese": "down_and_connor"
}
