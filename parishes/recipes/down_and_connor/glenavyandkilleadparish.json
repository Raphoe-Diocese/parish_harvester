      "fallback_selectors": [
        "a[href$='.pdf']",
        "a[href*='.pdf']"
      ]
    },
    {
      "action": "click",
      "selector": "a:has-text('Fourth')",
      "fallback_selectors": [
        "a[href*='fourth'][href$='.pdf']",
        "a[href$='.pdf']",
        "a[href*='.pdf']",
        "section > section:nth-of-type(2) > section > div:nth-of-type(1) > h5 > a"
      ]
    },
    {
      "action": "download",
      "url_pattern": "*.pdf"
    }
  ],
  "diocese": "down_and_connor"
